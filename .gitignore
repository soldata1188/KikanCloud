# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────
/.next/
/out/
/build

# ── Environment variables (NEVER commit secrets) ──────────
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local

# ── Testing artifacts ─────────────────────────────────────
/coverage
/playwright-report
/test-results

# ── TypeScript cache ──────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────
.vercel

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── Debug logs ────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Temp / dev-only scripts ───────────────────────────────
enforce_design.py
lint_output.txt

.vercel
